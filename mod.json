            "resources/*.png"
        ]
    },
    "api": {
        "include": [
            "include/*.hpp"
        ]
    },
    "links": {
        "homepage": "https://linktr.ee/Alphalaneous",
        "source": "https://github.com/Alphalaneous/Badgify",
        "community": "https://discord.gg/Txn2CA5dHF"
    },
    "tags": [
        "developer", "interface", "api"
    ],
    "settings": {
        "alternative-profile-badge-design": {
            "name": "Show Badges Under Username",
            "description": "Show badges under the username instead of next to it on the profile.",
            "type": "bool",
            "default": true
        }
    }
